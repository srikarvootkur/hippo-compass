# Public domains
ASSISTANT_DOMAIN=assistant.example.com
OPENCLAW_DOMAIN=openclaw.example.com

# Runtime
ENVIRONMENT=development
LOG_LEVEL=info
ASSISTANT_API_KEY=change-me-local-dev
DATABASE_URL=postgresql://assistant:assistant@postgres:5432/assistant
REDIS_URL=redis://redis:6379/0
HIPPO_COMPASS_API_URL=http://assistant-api:8080
HIPPO_COMPASS_API_KEY=change-me-local-dev

# OpenAI / specialist agent workflows
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Workflow services
LANGGRAPH_WORKFLOWS_URL=http://langgraph-workflows:8070
AGENTS_WORKFLOWS_URL=http://agents-workflows:8090

# Local Postgres container only. Use managed Postgres in production.
POSTGRES_DB=assistant
POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant

# OpenClaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Optional integrations
TELEGRAM_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CRONOMETER_API_KEY=

# Google Health API
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=http://localhost:8080/connectors/google-health/oauth/callback
GOOGLE_HEALTH_SCOPES=https://www.googleapis.com/auth/googlehealth.activity_and_fitness.readonly https://www.googleapis.com/auth/googlehealth.ecg.readonly https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly https://www.googleapis.com/auth/googlehealth.irn.readonly https://www.googleapis.com/auth/googlehealth.location.readonly https://www.googleapis.com/auth/googlehealth.nutrition.readonly https://www.googleapis.com/auth/googlehealth.profile.readonly https://www.googleapis.com/auth/googlehealth.settings.readonly https://www.googleapis.com/auth/googlehealth.sleep.readonly
